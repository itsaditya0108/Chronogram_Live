<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ===== PROPERTIES ===== -->
    <property name="LOG_DIR" value="D:/data/auth-service"/>
    <property name="MS_FLOW_DIR" value="${LOG_DIR}/ms-flow"/>

    <!-- ===== MS FLOW LOG (SPECIFIC OPERATIONS) ===== -->
    <appender name="MS_FLOW_FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>${MS_FLOW_DIR}/ms-flow.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>
                ${MS_FLOW_DIR}/ms-flow-%d{yyyy-MM-dd}.%i.log
            </fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
        </rollingPolicy>

        <encoder>
            <pattern>
                datetime=%d{yyyy-MM-dd HH:mm:ss.SSS}
                txId=%X{txId}
                level=%-5level
                message=%msg%n%n
            </pattern>
        </encoder>
    </appender>

    <!-- ===== LOGGERS ===== -->

    <!-- Specific flow logger for selective operations -->
    <logger name="live.chronogram.auth.ms"
            level="INFO"
            additivity="false">
        <appender-ref ref="MS_FLOW_FILE"/>
    </logger>

    <!-- ===== CONSOLE APP LOG ===== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root = Console logs for development -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
